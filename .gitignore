# Matlab reference files — never commit
BCKM/

# Build artifacts
*.egg-info/
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# OS
.DS_Store

# Data cache
~/.bca_cache/

# Pipeline dumps — regeneratable via run_var_counterfactuals.py --dump-mle
data/mle_dump_*.npz
bckm_replication/data/mle_dump_*.npz

# MLE result caches — content-addressed pickles of estimate_var_mle output.
# Reproducible from data + θ; no need to version them.
*.mle.pkl

# Octave run logs — regeneratable; can run into 10s-100s of MB.
# Keep the .mat result snapshots and CSV outputs in octave_output/;
# exclude verbose run logs regardless of extension.
bckm_replication/octave_output/*.log
bckm_replication/octave_output/*_log.txt

# Jupyter
.ipynb_checkpoints/

# Local secrets — never commit
.env
.env.*

# Local virtualenvs and stray Claude tooling state
.venv/
.claire/
