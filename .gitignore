# Matlab reference files — never commit
BCKM/

# Build artifacts
*.egg-info/
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# OS
.DS_Store

# Data cache
~/.bca_cache/

# Pipeline dumps — regeneratable via run_var_counterfactuals.py --dump-mle
data/mle_dump_*.npz

# Octave run logs — regeneratable; can run into 10s-100s of MB.
# Keep the .mat result snapshots and CSV outputs in octave_output/;
# exclude verbose run logs regardless of extension.
octave_output/*.log
octave_output/*_log.txt

# Jupyter
.ipynb_checkpoints/

# Local secrets — never commit
.env
.env.*
