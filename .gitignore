# Matlab reference files — never commit
BCKM/

# Build artifacts
*.egg-info/
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# OS
.DS_Store

# Data cache
~/.bca_cache/

# Pipeline dumps — regeneratable via run_var_counterfactuals.py --dump-mle
data/mle_dump_*.npz

# Octave run logs — regeneratable; can run into 10s-100s of MB.
# Keep the .mat result snapshots in octave_output/ (they're tiny and
# carry the actual numbers); only exclude the verbose run logs.
octave_output/*.log

# Jupyter
.ipynb_checkpoints/

# Local secrets — never commit
.env
.env.*
